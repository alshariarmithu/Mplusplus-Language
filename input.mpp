define number main()
start
    show(10 + 20 * 2);
    show("Hello World");
    show("Counting from 1 to 5:");
    loop (number i = 1; i < 6; i = i + 1)
    start
        show(i);
    finish
    
    when (5 > 2)
    start
        show("Five is indeed greater than two");
    finish

    number i = 0;
    repeat (i < 5) 
    start
        show(i);
        i = i + 1;
    finish
finish