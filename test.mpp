// Test program for M++ Language

// 1: Variable Declarations
number x = 10;
decimal pi = 3.14;
letter ch = 'A';

// 2: Assignments
x = x + 5;
pi = pi * 2;

// 3: Show statements
show(x);
show(pi);
show(ch);

// 4: Arithmetic expressions
number a = 7;
number b = 3;
number sum = a + b;
number diff = a - b;
number prod = a * b;
number quot = a / b;
number rem = a % b;

